# Copy this file to .env and fill in your values.
# Never commit your .env file.

# Strava API credentials (obtain from https://www.strava.com/settings/api)
STRAVA_ACCESS_TOKEN=your_access_token_here
STRAVA_REFRESH_TOKEN=your_refresh_token_here
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here
STRAVA_EXPIRES_AT=0  # Unix timestamp when access token expires

# Optional: SQLAlchemy database URL (defaults to SQLite)
DATABASE_URL=sqlite:///athlete_intelligence.db

# FastAPI settings
API_KEY=                          # Leave blank to disable auth in development
ENVIRONMENT=development           # Set to "production" to disable /docs and /redoc
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173  # Comma-separated CORS origins

# Strava webhook (required for real-time activity sync in production)
# Set this to any secret string, then use the same value when registering
# your webhook subscription with Strava via the push_subscriptions API.
STRAVA_WEBHOOK_VERIFY_TOKEN=      # e.g. a random UUID
# Your Strava athlete ID — used to validate incoming webhook events and reject
# events from other athletes (or spoofed requests). Find it at strava.com/athletes/me.
STRAVA_ATHLETE_ID=
